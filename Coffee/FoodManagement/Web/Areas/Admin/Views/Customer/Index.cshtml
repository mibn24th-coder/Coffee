@model IEnumerable<Core.Database.Models.Customer>

@{
	ViewBag.Title = "Khách hàng";
	Layout = "~/Areas/Admin/Views/Shared/_Admin.cshtml";
}


<section class="content">

	<div class="container-fluid">


		<div class="card">


			<div class="card-header">

				<h3 class="card-title">
					Khách hàng
				</h3>


			</div>




			<div class="card-body">


				<table id="customerTable"
					   class="table table-bordered table-striped">


					<thead>

						<tr>

							<th>
								#
							</th>

							<th>
								Họ tên
							</th>


							<th>
								Email
							</th>


							<th>
								Số điện thoại
							</th>


							<th>
								Ngày đăng ký
							</th>


							<th>
								Số đơn hàng
							</th>


						</tr>

					</thead>



					<tbody>


						@{
							int i = 1;
						}


						@foreach (var item in Model)
						{


							<tr>


								<td>
									@i
								</td>


								<td>
									@item.Name
								</td>


								<td>
									@item.Email
								</td>


								<td>
									@item.Phone
								</td>


								<td>
									@item.CreatedDate.ToString("dd/MM/yyyy")
								</td>


								<td>

									<span class="badge bg-primary">

										@item.Orders.Count

									</span>


								</td>


							</tr>


							i++;

						}



					</tbody>


				</table>



			</div>


		</div>


	</div>

</section>


@section Js {

	<script>
		$(function () {
			$('#customerTable').DataTable();
		});
	</script>

}