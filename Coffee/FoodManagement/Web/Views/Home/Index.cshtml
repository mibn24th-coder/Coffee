<!-- KHỐI VOUCHER KHUYẾN MÃI (DÁN NGAY DƯỚI BANNER) -->
<!-- ======================================================== -->
@if (vouchers != null && vouchers.Any())
{
    <section class="voucher-section mb-5 wow fadeInUp" data-wow-delay="0.1s">
        <div class="container">
            <div class="text-center mx-auto mb-4" style="max-width: 500px;">
                <p class="text-primary text-uppercase mb-1" style="letter-spacing: 1px;">// Ưu đãi hôm nay</p>
                <h3 class="font-weight-bold" style="color: #F57C00;;">
                    <i class="fas fa-gift mr-1"></i> Khuyến Mãi Đặc Biệt Cho Bạn
                </h3>
                <p class="text-muted small">Thu thập ngay mã giảm giá để thưởng thức nước và kem cực hời!</p>
            </div>

            <div class="row justify-content-center">
                @foreach (var voucher in vouchers)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6 mb-3">
                        <div class="coupon-card d-flex">
                            <!-- Phần bên trái: Giá trị giảm -->
                            <div class="coupon-left text-center d-flex flex-column justify-content-center align-items-center">
                                <div class="discount-val">
                                    @if (voucher.IsPercent)
                                    {
                                        <span>@((int)voucher.Discount)%</span>
                                    }
                                    else
                                    {
                                        <span>@((voucher.Discount / 1000).ToString("N0"))k</span>
                                    }
                                </div>
                                <small class="discount-lbl">GIẢM</small>
                            </div>

                            <!-- Nét đứt chia đôi vé -->
                            <div class="coupon-border"></div>

                            <!-- Phần bên phải: Thông tin & Nút lưu -->
                            <div class="coupon-right d-flex flex-column justify-content-between p-2 flex-grow-1">
                                <div>
                                    <h6 class="coupon-code font-weight-bold mb-1">Mã: @voucher.Code</h6>
                                    <p class="coupon-desc text-muted mb-0" style="font-size: 11px; line-height: 1.3;">
                                        @if (voucher.MinOrder.HasValue && voucher.MinOrder > 0)
                                        {
                                            <span>Đơn tối thiểu: @((voucher.MinOrder.Value / 1000).ToString("N0"))k</span>
                                        }
                                        else
                                        {
                                            <span>Mọi đơn hàng</span>
                                        }
                                        <br />
                                        Hạn dùng: @voucher.EndDate.ToString("dd/MM")
                                    </p>
                                </div>
                                <div class="text-right mt-1">
                                    <button class="btn btn-sm btn-outline-danger btn-copy-coupon py-0 px-2"
                                            style="font-size: 11px; border-radius: 12px;"
                                            data-code="@voucher.Code">
                                        Sao chép
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<style>
    .coupon-card {
        background: #FFFDF8;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #FFD9A0;
        box-shadow: 0 4px 12px rgba(255, 183, 77, 0.15);
        transition: all .3s ease;
    }

        .coupon-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(255, 183, 77, 0.35);
        }

    /* Phần cuống vé bên trái */
    .coupon-left {
        background: linear-gradient(135deg, #FF8A80 0%, #FFB74D 100%);
        color: white;
        width: 80px;
        min-width: 80px;
        padding: 10px 5px;
    }

    .discount-val {
        font-size: 20px;
        font-weight: bold;
        line-height: 1.1;
    }

    .discount-lbl {
        font-size: 10px;
        letter-spacing: 1px;
        opacity: .9;
    }

    /* Đường đứt giữa cuống vé */
    .coupon-border {
        border-left: 2px dashed #FFD9A0;
        position: relative;
    }

        .coupon-border::before,
        .coupon-border::after {
            content: "";
            position: absolute;
            width: 12px;
            height: 12px;
            background: #FFFDF8;
            border: 1px solid #FFD9A0;
            border-radius: 50%;
            left: -7px;
        }

        .coupon-border::before {
            top: -7px;
        }

        .coupon-border::after {
            bottom: -7px;
        }

    /* Phần bên phải thông tin */
    .coupon-right {
        background: #FFFDF8;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    .coupon-code {
        color: #E67E22;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .5px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const copyButtons = document.querySelectorAll(".btn-copy-coupon");
        copyButtons.forEach(button => {
            button.addEventListener("click", function () {
                const code = this.getAttribute("data-code");
                navigator.clipboard.writeText(code).then(() => {
                    this.textContent = "Đã lưu!";
                    this.classList.remove("btn-outline-danger");
                    this.classList.add("btn-success");
                    this.style.color = "#fff";

                    setTimeout(() => {
                        this.textContent = "Sao chép";
                        this.classList.remove("btn-success");
                        this.classList.add("btn-outline-danger");
                        this.style.color = "";
                    }, 2000);
                });
            });
        });
    });
</script>
