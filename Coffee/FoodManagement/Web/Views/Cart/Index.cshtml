@model List<Core.Database.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "~/Views/Shared/_Site.cshtml";
}

<!-- Page Header Start -->
<div class="container-fluid page-header py-6 my-6 mt-0 wow fadeIn"
     data-wow-delay="0.1s">
    <div class="container text-center">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            Giỏ hàng
        </h1>

        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item">
                    <a class="text-white" href="/">Trang chủ</a>
                </li>

                <li class="breadcrumb-item text-primary active">
                    Giỏ hàng
                </li>
            </ol>
        </nav>
    </div>
</div>
<!-- Page Header End -->


<div class="container py-5">

    <h2 class="mb-4">
        <i class="fa fa-shopping-cart text-primary"></i>
        Giỏ hàng của bạn
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            <i class="fa fa-shopping-cart"></i>
            Giỏ hàng đang trống.
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle text-center">

            <thead class="table-dark">
                <tr>
                    <th width="130">Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th width="150">Giá</th>
                    <th width="180">Số lượng</th>
                    <th width="180">Thành tiền</th>
                    <th width="120">Thao tác</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <img src="@item.Picture"
                                 class="img-fluid rounded"
                                 style="height:100px;width:100px;object-fit:cover;">
                        </td>

                        <td class="fw-bold">
                            @item.Title
                        </td>

                        <td>
                            @String.Format("{0:N0}", item.Price) đ
                        </td>

                        <td>

                            <a href="/Cart/Decrease?id=@item.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-minus"></i>
                            </a>

                            <span class="mx-3 fw-bold fs-5">
                                @item.Quantity
                            </span>

                            <a href="/Cart/Increase?id=@item.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-plus"></i>
                            </a>

                        </td>

                        <td class="text-danger fw-bold">
                            @String.Format("{0:N0}", item.Price * item.Quantity) đ
                        </td>

                        <td>

                            <a href="/Cart/Delete?id=@item.Id"
                               class="btn btn-danger btn-sm">

                                <i class="fa fa-trash"></i>
                                Xóa

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="row mt-5">

            <div class="col-md-6">
                <a href="/Product"
                   class="btn btn-outline-primary mb-3">
                    <i class="fa fa-arrow-left"></i>
                    Tiếp tục mua hàng
                </a>
            </div>

            <!-- Khối tính tiền và áp dụng Voucher -->
            <div class="col-md-6 text-end">
                <div class="card p-4 shadow-sm border mb-3 text-start d-inline-block" style="min-width: 350px;">
                    <h5 class="mb-3"><i class="fa fa-gift text-primary me-2"></i>Mã giảm giá</h5>
                    <div class="input-group mb-3">
                        <input type="text" id="voucher-code" class="form-control" placeholder="Nhập mã (Ví dụ: D001)">
                        <button class="btn btn-primary text-white" id="btn-apply-voucher" type="button">Áp dụng</button>
                    </div>

                    <div class="d-flex justify-content-between mb-2 fs-5">
                        <span>Tạm tính:</span>
                        <span id="temp-total" class="fw-bold text-dark">
                            @String.Format("{0:N0}", Model.Sum(x => x.Price * x.Quantity))đ
                        </span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 fs-5 text-danger">
                        <span>Được giảm:</span>
                        <span id="discount-amount" class="fw-bold">-0 đ</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fs-4 fw-bold">
                        <span>Tổng tiền:</span>
                        <span id="final-total" class="text-primary">
                            @String.Format("{0:N0}", Model.Sum(x => x.Price * x.Quantity)) đ
                        </span>
                    </div>
                </div>

                <div class="w-100">
                    <a href="/Cart/Checkout"
                       class="btn btn-success btn-lg px-5">
                        <i class="fa fa-credit-card me-2"></i>
                        Xác nhận thanh toán
                    </a>
                </div>
            </div>

        </div>
    }

</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#btn-apply-voucher").click(function () {
                var code = $("#voucher-code").val().trim();
                // Lấy số tiền tạm tính, loại bỏ ký tự không phải số
                var tempTotal = parseFloat($("#temp-total").text().replace(/[^0-9]/g, ''));

                if (code === "") {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Thông báo',
                        text: 'Vui lòng điền mã giảm giá trước khi nhấn áp dụng!'
                    });
                    return;
                }

                $.ajax({
                    url: '/Cart/ApplyVoucher',
                    type: 'POST',
                    data: { code: code, temporaryTotal: tempTotal },
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: response.message
                            });
                            // Cập nhật giá trị hiển thị giảm giá và tổng tiền mới trên giao diện
                            $("#discount-amount").text("-" + response.discountAmount.toLocaleString('vi-VN') + " đ");
                            $("#final-total").text(response.newTotal.toLocaleString('vi-VN') + " đ");
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Thất bại!',
                                text: response.message
                            });
                        }
                    },
                    error: function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi hệ thống',
                            text: 'Không thể kết nối với máy chủ!'
                        });
                    }
                });
            });
        });
    </script>
}