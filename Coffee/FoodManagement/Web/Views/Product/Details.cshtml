@model Core.Database.Models.Product

@{
    Layout = "_Site";
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container-fluid page-header py-6 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center pt-5 pb-3">
        <h1 class="display-4 text-white animated slideInDown">
            Chi tiết sản phẩm
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a class="text-white" href="/">Trang chủ</a></li>
                <li class="breadcrumb-item text-primary active" aria-current="page">
                    Chi tiết sản phẩm
                </li>
            </ol>
        </nav>
    </div>
</div>
@* //// *@
<div class="container py-5">
    <div class="row">

        <!-- Ảnh bên trái -->
        <div class="col-md-6 text-center">
            <img id="productImage"
                 src="@Model.Picture"
                 class="img-fluid rounded shadow"
                 style="width:100%; max-height:500px; object-fit:cover;" />
        </div>

        <!-- Thông tin bên phải -->
        <div class="col-md-6">

            <h2>@Model.Title</h2>

            <h3 class="text-danger mt-3">
                @Model.Price đ
            </h3>

            <hr />

            <h5>Mô tả</h5>

            <div>
                @Html.Raw(Model.Intro)
            </div>

            

            <hr />

            <h5>Thông tin sản phẩm</h5>

            <div>
                @Html.Raw(Model.Content)
            </div>

            <br />

            <a href="#"
               class="btn btn-primary btn-lg add-cart"
               data-id="@Model.Id">

                <i class="fa fa-shopping-cart"></i>
                Thêm vào giỏ hàng

            </a>

        </div>

    </div>
</div>
@* //// *@
<script>
        $(document).on("click", ".add-cart", function (e) {

        e.preventDefault();

        var id = $(this).data("id");

        $.post("/Cart/Add", { id: id }, function (res) {

            // Chưa đăng nhập
            if (res.login) {

                Swal.fire({
                    icon: "warning",
                    title: "Bạn chưa đăng nhập <i class='fa fa-heart text-danger'></i>",
                    html: "Mời bạn đăng nhập tài khoản để rinh sản phẩm vào giỏ hàng.",
                    confirmButtonText: "Đăng nhập"
                }).then((result) => {

                    if (result.isConfirmed) {
                        window.location = "/Account/Login";
                    }

                });

                return;
            }

            // Thêm thành công
            if (res.success) {

                LoadCartCount();

                Swal.fire({
                    icon: "success",
                    title: "Đã thêm vào giỏ hàng",
                    text: "Sản phẩm đã được thêm vào giỏ hàng.",
                    timer: 1500,
                    showConfirmButton: false
                });

            }

        });

    });

    function LoadCartCount() {

        $.get("/Cart/GetCount", function (count) {

            $("#cart-count").text(count);

        });

    }
</script>
